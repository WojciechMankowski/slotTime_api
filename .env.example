APP_ENV=production

# Supabase: Settings → Database → Connection string → URI (użyj portu 5432, nie 6543)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# Docker lokalnie:
# DATABASE_URL=postgresql://slotuser:ZMIEN_HASLO_DB@db:5432/slotbooking
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Generuj: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=WYGENERUJ_LOSOWY_KLUCZ_MIN_32_ZNAKI
JWT_EXPIRE_HOURS=8
JWT_REFRESH_DAYS=7

# Twoja domena wystawiona przez Cloudflare Tunnel
APP_CORS_ORIGINS=https://TWOJA_DOMENA.pl

# Hasło bazy PostgreSQL — musi być zgodne z POSTGRES_PASSWORD w docker-compose
POSTGRES_PASSWORD=ZMIEN_HASLO_DB

# Power Automate HTTP trigger URL
POWER_AUTOMATE_URL=https://...

